# Variables d'environnement pour Railway - Cabinet Avocat

# Django Configuration
DEBUG=False
SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=CabinetAvocat.settings_production

# Database (Railway MySQL - automatiquement configuré)
MYSQL_HOST=containers-us-west-xxx.railway.app
MYSQL_PORT=3306
MYSQL_DATABASE=railway
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password

# JSReport Configuration
JSREPORT_URL=https://your-jsreport-service.railway.app
JSREPORT_USERNAME=admin
JSREPORT_PASSWORD=your-secure-password
JSREPORT_TIMEOUT=120
JSREPORT_COOKIE_SECRET=your-cookie-secret

# Security
ALLOWED_HOSTS=.railway.app,.up.railway.app,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://*.railway.app,https://*.up.railway.app

# Logging
DJANGO_LOG_LEVEL=INFO

# Railway Environment (automatique)
RAILWAY_ENVIRONMENT=production
PORT=8000